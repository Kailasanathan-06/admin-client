# ── Django ──────────────────────────────────────────────────────────
DJANGO_SECRET_KEY="django-insecure-change-me-in-production-abc123"
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS="0.0.0.0,127.0.0.1,localhost"

# ── Supabase PostgreSQL (Django ORM) ────────────────────────────────
# Preferred: single connection string
SUPABASE_DATABASE_URL="postgresql://user:password@host:5432/postgres"
# OR set individually:
SUPABASE_DB_NAME="postgres"
SUPABASE_DB_USER="postgres"
SUPABASE_DB_PASSWORD="your-supabase-db-password"
SUPABASE_DB_HOST="db.xxxxxxxxxxxxxx.supabase.co"
SUPABASE_DB_PORT="5432"

# ── Supabase Client (Direct API queries) ────────────────────────────
SUPABASE_URL="https://xxxxxxxxxxxxxx.supabase.co"
SUPABASE_SERVICE_KEY="service_role_key_here"
SUPABASE_JWT_SECRET="your-jwt-secret-here"
